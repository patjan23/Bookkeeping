<UserControl x:Class="Bookkeeping.App.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="ReportsPage"
             Background="{StaticResource AppBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header + period selectors -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Monthly Report" Style="{StaticResource H1}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Year:" Style="{StaticResource Body}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox AutomationProperties.AutomationId="Filter_Year"
                              ItemsSource="{Binding Years}"
                              SelectedItem="{Binding SelectedYear}"
                              Style="{StaticResource InputCombo}" Width="90" Margin="0,0,12,0"/>
                    <TextBlock Text="Month:" Style="{StaticResource Body}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox AutomationProperties.AutomationId="Filter_Month"
                              ItemsSource="{Binding Months}"
                              SelectedItem="{Binding SelectedMonth}"
                              Style="{StaticResource InputCombo}" Width="70"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Report body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20">

                <!-- KPI cards -->
                <UniformGrid Columns="3" Margin="0,0,0,24">
                    <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="INCOME"   Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TotalIncome, StringFormat=C}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource AccentGreenBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Margin="5,0">
                        <StackPanel>
                            <TextBlock Text="EXPENSES" Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TotalExpenses, StringFormat=C}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource AccentRedBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="NET"      Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Net, StringFormat=C}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Charts -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Income chart -->
                    <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Income by Category" Style="{StaticResource H2}" Margin="0,0,0,16"/>
                            <ItemsControl AutomationProperties.Name="IncomeChart"
                                          ItemsSource="{Binding IncomeSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding CategoryName}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border Grid.Column="1" Height="16" CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    MinWidth="4"
                                                    Width="{Binding RelativeWidth}"
                                                    Background="{StaticResource AccentGreenBrush}"
                                                    Opacity="0.75"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding TotalAmount, StringFormat=C}"
                                                       FontSize="11" HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Expense chart -->
                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Expenses by Category" Style="{StaticResource H2}" Margin="0,0,0,16"/>
                            <ItemsControl AutomationProperties.Name="ExpenseChart"
                                          ItemsSource="{Binding ExpenseSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding CategoryName}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border Grid.Column="1" Height="16" CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    MinWidth="4"
                                                    Width="{Binding RelativeWidth}"
                                                    Background="{StaticResource AccentRedBrush}"
                                                    Opacity="0.75"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding TotalAmount, StringFormat=C}"
                                                       FontSize="11" HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </Grid>

                <!-- Error message -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           Margin="0,16,0,0" FontSize="12"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToVisibility}}"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Border Grid.RowSpan="2"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                Style="{StaticResource LoadingOverlay}">
            <ProgressBar IsIndeterminate="True" Width="220" Height="4"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="{StaticResource PrimaryBrush}"/>
        </Border>

    </Grid>
</UserControl>
