<UserControl x:Class="Bookkeeping.App.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Bookkeeping.Core.Models;assembly=Bookkeeping.Core"
             AutomationProperties.Name="TransactionsPage"
             Background="{StaticResource AppBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Transactions" Style="{StaticResource H1}" VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        AutomationProperties.AutomationId="Btn_AddTransaction"
                        AutomationProperties.Name="Btn_AddTransaction"
                        Content="+ Add Transaction"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddTransactionCommand}"/>
            </Grid>
        </Border>

        <!-- ── Filters ── -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,12">
            <WrapPanel Orientation="Horizontal">

                <TextBox AutomationProperties.AutomationId="Filter_Search"
                         AutomationProperties.Name="Filter_Search"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputBox}"
                         Width="200" Margin="0,0,10,6">
                    <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </TextBox.Resources>
                </TextBox>

                <DatePicker AutomationProperties.AutomationId="Filter_FromDate"
                            SelectedDate="{Binding FromDate}"
                            Style="{StaticResource InputDate}"
                            Width="140" Margin="0,0,10,6"/>

                <DatePicker AutomationProperties.AutomationId="Filter_ToDate"
                            SelectedDate="{Binding ToDate}"
                            Style="{StaticResource InputDate}"
                            Width="140" Margin="0,0,10,6"/>

                <ComboBox AutomationProperties.AutomationId="Filter_Type"
                          SelectedItem="{Binding FilterType}"
                          Style="{StaticResource InputCombo}"
                          Width="130" Margin="0,0,10,6">
                    <ComboBox.Items>
                        <x:Null/>
                        <models:TransactionType>Income</models:TransactionType>
                        <models:TransactionType>Expense</models:TransactionType>
                    </ComboBox.Items>
                </ComboBox>

                <Button Content="Clear"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearFiltersCommand}"
                        Margin="0,0,0,6"/>
            </WrapPanel>
        </Border>

        <!-- ── Data grid ── -->
        <DataGrid Grid.Row="2"
                  AutomationProperties.Name="TransactionsGrid"
                  ItemsSource="{Binding Transactions}"
                  SelectedItem="{Binding SelectedTransaction}"
                  Style="{StaticResource ModernGrid}"
                  ColumnHeaderStyle="{StaticResource GridColumnHeader}"
                  Margin="24,16">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Date"        Width="110"
                                    Binding="{Binding Date, StringFormat=dd MMM yyyy}"/>
                <DataGridTextColumn Header="Description" Width="*"
                                    Binding="{Binding Description}"/>
                <DataGridTextColumn Header="Account"     Width="120"
                                    Binding="{Binding Account.Name}"/>
                <DataGridTextColumn Header="Category"    Width="130"
                                    Binding="{Binding Category.Name}"/>

                <!-- Type chip column -->
                <DataGridTemplateColumn Header="Type" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#DCFCE7"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}"
                                                         Value="{x:Static models:TransactionType.Expense}">
                                                <Setter Property="Background" Value="#FEE2E2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Type}" FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#166534"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}"
                                                             Value="{x:Static models:TransactionType.Expense}">
                                                    <Setter Property="Foreground" Value="#991B1B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Amount column -->
                <DataGridTemplateColumn Header="Amount" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,8,0">
                                <TextBlock.Foreground>
                                    <Binding Path="Type" Converter="{StaticResource AmountColor}"/>
                                </TextBlock.Foreground>
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource DecimalSign}">
                                        <Binding Path="Amount"/>
                                        <Binding Path="Type"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Actions column -->
                <DataGridTemplateColumn Header="" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Edit"
                                        AutomationProperties.Name="Btn_EditTransaction"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,4" FontSize="12"
                                        Command="{Binding DataContext.EditTransactionCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Margin="2"/>
                                <Button Content="Del"
                                        AutomationProperties.Name="Btn_DeleteTransaction"
                                        Style="{StaticResource DangerButton}"
                                        Padding="8,4" FontSize="12"
                                        Command="{Binding DataContext.DeleteTransactionCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Margin="2"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Status ── -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Margin="24,0,24,12" FontSize="12">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Loading overlay -->
        <Border Grid.RowSpan="4"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                Style="{StaticResource LoadingOverlay}">
            <ProgressBar IsIndeterminate="True" Width="240" Height="4"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="{StaticResource PrimaryBrush}"/>
        </Border>

    </Grid>
</UserControl>
