<Window x:Class="Bookkeeping.App.Views.AddEditTransactionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="480" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBgBrush}"
        AutomationProperties.Name="AddEditTransactionDialog">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="{Binding Title}" Style="{StaticResource H2}" Margin="0,0,0,20"/>

        <!-- Amount -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Amount" Style="{StaticResource FormLabel}"/>
            <TextBox AutomationProperties.AutomationId="Field_Amount"
                     AutomationProperties.Name="Field_Amount"
                     Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputBox}"/>
            <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, RelativeSource={RelativeSource Self}}"
                       Foreground="{StaticResource ErrorBrush}" FontSize="11" Margin="0,2,0,0"
                       Visibility="{Binding (Validation.HasError), RelativeSource={RelativeSource Self},
                                    Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>

        <!-- Description -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Description" Style="{StaticResource FormLabel}"/>
            <TextBox AutomationProperties.AutomationId="Field_Description"
                     AutomationProperties.Name="Field_Description"
                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputBox}"/>
        </StackPanel>

        <!-- Date -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Date" Style="{StaticResource FormLabel}"/>
            <DatePicker AutomationProperties.AutomationId="Field_Date"
                        SelectedDate="{Binding Date}"
                        Style="{StaticResource InputDate}" HorizontalAlignment="Stretch"/>
        </StackPanel>

        <!-- Type -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Text="Type" Style="{StaticResource FormLabel}"/>
            <ComboBox AutomationProperties.AutomationId="Field_Type"
                      AutomationProperties.Name="Field_Type"
                      ItemsSource="{Binding TransactionTypes}"
                      SelectedItem="{Binding TransactionType}"
                      Style="{StaticResource InputCombo}"/>
        </StackPanel>

        <!-- Category -->
        <StackPanel Grid.Row="5" Margin="0,0,0,12">
            <TextBlock Text="Category" Style="{StaticResource FormLabel}"/>
            <ComboBox AutomationProperties.AutomationId="Field_Category"
                      AutomationProperties.Name="Field_Category"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      DisplayMemberPath="Name"
                      Style="{StaticResource InputCombo}"/>
        </StackPanel>

        <!-- Account -->
        <StackPanel Grid.Row="6" Margin="0,0,0,20">
            <TextBlock Text="Account" Style="{StaticResource FormLabel}"/>
            <ComboBox AutomationProperties.AutomationId="Field_Account"
                      AutomationProperties.Name="Field_Account"
                      ItemsSource="{Binding Accounts}"
                      SelectedItem="{Binding SelectedAccount}"
                      DisplayMemberPath="Name"
                      Style="{StaticResource InputCombo}"/>
        </StackPanel>

        <!-- Validation summary -->
        <TextBlock Grid.Row="7"
                   Text="{Binding ValidationSummary}"
                   Foreground="{StaticResource ErrorBrush}"
                   TextWrapping="Wrap"
                   Visibility="{Binding ValidationSummary,
                                Converter={StaticResource InverseVisibility},
                                ConverterParameter=empty}"
                   Margin="0,0,0,12" FontSize="12"/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button AutomationProperties.AutomationId="Btn_Cancel"
                    AutomationProperties.Name="Btn_Cancel"
                    Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}"
                    Margin="0,0,10,0"/>
            <Button AutomationProperties.AutomationId="Btn_Save"
                    AutomationProperties.Name="Btn_Save"
                    Content="Save"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"/>
        </StackPanel>

        <!-- Loading overlay -->
        <Border Grid.RowSpan="9"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                Style="{StaticResource LoadingOverlay}">
            <ProgressBar IsIndeterminate="True" Width="180" Height="4"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="{StaticResource PrimaryBrush}"/>
        </Border>

    </Grid>
</Window>
