<Application x:Class="Bookkeeping.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Bookkeeping.App.ViewModels"
             xmlns:views="clr-namespace:Bookkeeping.App.Views"
             xmlns:conv="clr-namespace:Bookkeeping.App.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml"/>
                <ResourceDictionary Source="Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Converters ── -->
            <conv:BoolToVisibilityConverter          x:Key="BoolToVisibility"/>
            <conv:BoolToVisibilityConverter          x:Key="InverseVisibility"
                                                     TrueValue="Collapsed" FalseValue="Visible"/>
            <conv:InverseBoolConverter               x:Key="InverseBool"/>
            <conv:AmountColorConverter               x:Key="AmountColor"/>
            <conv:DecimalSignConverter               x:Key="DecimalSign"/>
            <conv:HexColorToBrushConverter           x:Key="HexToBrush"/>
            <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibility"/>

            <!-- ── ViewModel → View routing ── -->
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TransactionsViewModel}">
                <views:TransactionsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:CategoriesViewModel}">
                <views:CategoriesView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AccountsViewModel}">
                <views:AccountsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                <views:ReportsView/>
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>
