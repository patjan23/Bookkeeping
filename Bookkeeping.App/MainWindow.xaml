<Window x:Class="Bookkeeping.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bookkeeping" Height="700" Width="1100"
        MinHeight="560" MinWidth="800"
        Background="{StaticResource AppBgBrush}"
        AutomationProperties.Name="MainWindow"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ Sidebar ══════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}">
            <DockPanel>

                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,16">
                    <StackPanel>
                        <TextBlock Text="&#x1F4B0;" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="Bookkeeping"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextOnDarkBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Rectangle DockPanel.Dock="Top" Height="1" Margin="16,0"
                           Fill="{StaticResource SidebarHoverBrush}"/>

                <!-- Nav links -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">

                    <!-- Dashboard -->
                    <Button AutomationProperties.AutomationId="Nav_Dashboard"
                            AutomationProperties.Name="Nav_Dashboard"
                            Content="  Dashboard"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Dashboard">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveRoute}" Value="Dashboard">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Transactions -->
                    <Button AutomationProperties.AutomationId="Nav_Transactions"
                            AutomationProperties.Name="Nav_Transactions"
                            Content="  Transactions"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Transactions">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveRoute}" Value="Transactions">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Categories -->
                    <Button AutomationProperties.AutomationId="Nav_Categories"
                            AutomationProperties.Name="Nav_Categories"
                            Content="  Categories"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Categories">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveRoute}" Value="Categories">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Accounts -->
                    <Button AutomationProperties.AutomationId="Nav_Accounts"
                            AutomationProperties.Name="Nav_Accounts"
                            Content="  Accounts"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Accounts">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveRoute}" Value="Accounts">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Reports -->
                    <Button AutomationProperties.AutomationId="Nav_Reports"
                            AutomationProperties.Name="Nav_Reports"
                            Content="  Reports"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Reports">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveRoute}" Value="Reports">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══ Content + status bar ═════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page content routed by DataTemplates in App.xaml -->
            <ContentControl Grid.Row="0"
                            Content="{Binding CurrentPage}"
                            AutomationProperties.Name="PageContent"/>

            <!-- Status bar -->
            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,5">
                <TextBlock AutomationProperties.AutomationId="StatusBar"
                           AutomationProperties.Name="StatusBar"
                           FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text"      Value="{Binding StatusMessage}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </Grid>
    </Grid>
</Window>
